# OMyAgents V9 - Git Ignore

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
*.tgz

# Environment files (contain sensitive data)
config.env
.env
.env.local
.env.*.local

# Database files (SQLite)
data/*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Logs
logs/
*.log

# Temporary test files
temp_tests/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Backup files
*.bak
*.backup
